return;
}

idx = leerOpcion("Cual trabajador desea visualizar?: ", 1, totalTrabajadores);

printf("\n===== TRABAJADOR #%d =====\n", idx);

if (idx <= hospitales[h].cDoctores) {
idx = idx - 1;
printf("Tipo: DOCTOR\n");
printf("Nombre: %s\n", hospitales[h].Doctores[idx].Nombre);
printf("Numero trabajador: %d\n", hospitales[h].Doctores[idx].Trabajador.NumTrabajador);
printf("Sindicalizado: %s\n",
hospitales[h].Doctores[idx].Trabajador.Sindicalizado ? "SI" : "NO");
} else {
idx = idx - hospitales[h].cDoctores - 1;
printf("Tipo: INTENDENCIA\n");
printf("Nombre: %s\n", hospitales[h].Intendentes[idx].Nombre);
printf("Numero trabajador: %d\n", hospitales[h].Intendentes[idx].Trabajador.NumTrabajador);
printf("Sindicalizado: %s\n",
hospitales[h].Intendentes[idx].Trabajador.Sindicalizado ? "SI" : "NO");
}
}

