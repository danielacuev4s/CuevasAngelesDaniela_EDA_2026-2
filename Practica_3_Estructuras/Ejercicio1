}
} while (op != 4);
}

void agregarDoctor(int idxHospital) {
int op, idx, esp;
int sindicalizado;

if (hospitales[idxHospital].cDoctores >= MAX_DOCTORES) {
printf("Ya no se pueden agregar mas doctores en este hospital.\n");
return;
}

idx = hospitales[idxHospital].cDoctores;
limpiarDoctor(&hospitales[idxHospital].Doctores[idx]);

do {
printf("\n--- AGREGAR DOCTOR #%d ---\n", idx + 1);
printf("1. Nombre\n");
printf("2. Edad\n");
printf("3. Numero de trabajador (4 digitos)\n");
printf("4. Sindicalizado\n");
printf("5. Asignar especialidad existente\n");
printf("6. Guardar y regresar\n");
op = leerOpcion("Seleccion: ", 1, 6);

switch (op) {
case 1:
leerCadena("Nombre del doctor: ",
hospitales[idxHospital].Doctores[idx].Nombre,
MAX_NOMBRE);
break;

case 2:
hospitales[idxHospital].Doctores[idx].Edad =
leerEntero("Edad del doctor: ");
if (hospitales[idxHospital].Doctores[idx].Edad < 0) {
hospitales[idxHospital].Doctores[idx].Edad = 0;
}
break;

case 3:
hospitales[idxHospital].Doctores[idx].Trabajador.NumTrabajador =
leerNumero4Digitos("Numero de trabajador: ");
break;

case 4:
sindicalizado = leerOpcion("Sindicalizado? (1=Si, 0=No): ", 0, 1);
hospitales[idxHospital].Doctores[idx].Trabajador.Sindicalizado = sindicalizado;
break;

case 5:
if (hospitales[idxHospital].cEspecialidades == 0) {
printf("No hay especialidades registradas en este hospital.\n");
} else {
printf("Especialidades almacenadas: %d\n", hospitales[idxHospital].cEspecialidades);
esp = leerOpcion("Seleccione especialidad: ",
1,
hospitales[idxHospital].cEspecialidades);

/* Copia campo por campo, sin asignacion directa */
copiarEspecialidad(
&hospitales[idxHospital].Doctores[idx].Especialidad,
&hospitales[idxHospital].Especialidades[esp - 1]
);

printf("Especialidad asignada al doctor.\n");
}
break;

case 6:
/* Cantidad de pacientes inicia en 0 */
hospitales[idxHospital].Doctores[idx].CantidadPacientes = 0;
hospitales[idxHospital].cDoctores++;
recalcularSistemaHospital(idxHospital);
printf("Doctor guardado correctamente.\n");
break;
}
} while (op != 6);
}

