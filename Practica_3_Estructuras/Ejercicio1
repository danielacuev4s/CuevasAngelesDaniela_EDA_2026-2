#include <stdio.h>
#include <string.h>
#include <stdlib.h>

#define MAX_HOSPITALES 2
#define MAX_PACIENTES 10
#define MAX_DOCTORES 20
#define MAX_INTENDENTES 15
#define MAX_ESPECIALIDADES 4
#define MAX_EQUIPOS 30

#define MAX_NOMBRE 31 /* 30 caracteres + '\0' */
#define MAX_DIRECCION 41 /* 40 caracteres + '\0' */

/* =========================================================
===================== ESTRUCTURAS ========================
========================================================= */

/* EQUIPO MEDICO */
struct EQUIPO_MEDICO {
char Nombre[MAX_NOMBRE];
char Marca[MAX_NOMBRE];
char Modelo[MAX_NOMBRE];
};

/* ESPECIALIDAD */
struct ESPECIALIDAD {
char Nombre[MAX_NOMBRE];
int CantidadDoctores;
int CantidadPacientes;
struct EQUIPO_MEDICO EquipoMedico;
};

/* TRABAJADOR */
struct TRABAJADOR {
int NumTrabajador; /* Entero de 4 dígitos */
int Sindicalizado; /* 1 = Sí, 0 = No */
};

/* DOCTOR */
struct DOCTOR {
char Nombre[MAX_NOMBRE];
int Edad;
struct ESPECIALIDAD Especialidad;
struct TRABAJADOR Trabajador;
int CantidadPacientes;
};

/* INTENDENCIA */
struct INTENDENCIA {
char Nombre[MAX_NOMBRE];
int Edad;
struct TRABAJADOR Trabajador;
};

/*
Estructura auxiliar para evitar recursión infinita en C.
La consigna pide HOSPITAL dentro de PACIENTE, pero en C
no puede meterse una estructura dentro de sí misma de forma
completa; por eso se guarda aquí la parte básica del hospital.
*/
struct HOSPITAL_BASICO {
char Nombre[MAX_NOMBRE];
char Direccion[MAX_DIRECCION];
};

/* PACIENTE */
struct PACIENTE {
char Nombre[MAX_NOMBRE];
int Edad;
int NumPaciente; /* Entero de 4 dígitos */
struct DOCTOR Doctor;
struct ESPECIALIDAD Especialidad;
struct HOSPITAL_BASICO Hospital;
};

/* HOSPITAL */
struct HOSPITAL {
char Nombre[MAX_NOMBRE];
char Direccion[MAX_DIRECCION];

struct PACIENTE Pacientes[MAX_PACIENTES];
struct DOCTOR Doctores[MAX_DOCTORES];
struct INTENDENCIA Intendentes[MAX_INTENDENTES];
struct ESPECIALIDAD Especialidades[MAX_ESPECIALIDADES];
struct EQUIPO_MEDICO Equipos[MAX_EQUIPOS];

int cPacientes;
int cDoctores;
int cIntendentes;
int cEspecialidades;
int cEquipos;
};

/* =========================================================
================= VARIABLES GLOBALES ====================
========================================================= */

struct HOSPITAL hospitales[MAX_HOSPITALES];
int totalHospitales = 0;

/* =========================================================
================= FUNCIONES AUXILIARES ==================
========================================================= */

/* Limpia el buffer de entrada */
void limpiarBuffer() {
int c;
while ((c = getchar()) != '\n' && c != EOF) {}
}

/* Lee un entero con mensaje */
int leerEntero(const char *mensaje) {
int valor;
while (1) {
printf("%s", mensaje);
if (scanf("%d", &valor) == 1) {
limpiarBuffer();
return valor;
}
printf("Entrada invalida. Intente de nuevo.\n");
limpiarBuffer();
}
}

/* Lee una opción entre min y max */
int leerOpcion(const char *mensaje, int min, int max) {
int op;
do {
op = leerEntero(mensaje);
if (op < min || op > max) {
printf("Opcion invalida. Debe estar entre %d y %d.\n", min, max);
}
} while (op < min || op > max);
return op;
}

/* Lee una cadena segura con espacios */
void leerCadena(const char *mensaje, char *destino, int tam) {
char buffer[256];

printf("%s", mensaje);
if (fgets(buffer, sizeof(buffer), stdin) != NULL) {
buffer[strcspn(buffer, "\n")] = '\0';
strncpy(destino, buffer, tam - 1);
destino[tam - 1] = '\0';
} else {
destino[0] = '\0';
}
}

/* Valida un número de 4 dígitos */
int leerNumero4Digitos(const char *mensaje) {
int numero;
do {
numero = leerEntero(mensaje);
if (numero < 1000 || numero > 9999) {
printf("Debe ser un numero entero de 4 digitos.\n");
}
} while (numero < 1000 || numero > 9999);
return numero;
}

/* =========================================================
============ FUNCIONES DE LIMPIEZA / INICIALIZACION =====
========================================================= */

void limpiarEquipo(struct EQUIPO_MEDICO *e) {
strcpy(e->Nombre, "");
strcpy(e->Marca, "");
strcpy(e->Modelo, "");
}

void limpiarTrabajador(struct TRABAJADOR *t) {
t->NumTrabajador = 0;
t->Sindicalizado = 0;
}

void limpiarEspecialidad(struct ESPECIALIDAD *e) {
strcpy(e->Nombre, "");
e->CantidadDoctores = 0;
e->CantidadPacientes = 0;
limpiarEquipo(&e->EquipoMedico);
}

void limpiarDoctor(struct DOCTOR *d) {
strcpy(d->Nombre, "");
d->Edad = 0;
limpiarEspecialidad(&d->Especialidad);
limpiarTrabajador(&d->Trabajador);
d->CantidadPacientes = 0;
}

void limpiarIntendencia(struct INTENDENCIA *i) {
strcpy(i->Nombre, "");
i->Edad = 0;
limpiarTrabajador(&i->Trabajador);
}

void limpiarHospitalBasico(struct HOSPITAL_BASICO *h) {
strcpy(h->Nombre, "");
strcpy(h->Direccion, "");
}

void limpiarPaciente(struct PACIENTE *p) {
strcpy(p->Nombre, "");
p->Edad = 0;
p->NumPaciente = 0;
limpiarDoctor(&p->Doctor);
limpiarEspecialidad(&p->Especialidad);
limpiarHospitalBasico(&p->Hospital);
}

void limpiarHospital(struct HOSPITAL *h) {
int i;

strcpy(h->Nombre, "");
strcpy(h->Direccion, "");

for (i = 0; i < MAX_PACIENTES; i++) {
limpiarPaciente(&h->Pacientes[i]);
}

for (i = 0; i < MAX_DOCTORES; i++) {
limpiarDoctor(&h->Doctores[i]);
}

for (i = 0; i < MAX_INTENDENTES; i++) {
limpiarIntendencia(&h->Intendentes[i]);
}

for (i = 0; i < MAX_ESPECIALIDADES; i++) {
limpiarEspecialidad(&h->Especialidades[i]);
}

for (i = 0; i < MAX_EQUIPOS; i++) {
limpiarEquipo(&h->Equipos[i]);
}

h->cPacientes = 0;
h->cDoctores = 0;
h->cIntendentes = 0;
h->cEspecialidades = 0;
h->cEquipos = 0;
}

void inicializarSistema() {
int i;
for (i = 0; i < MAX_HOSPITALES; i++) {
limpiarHospital(&hospitales[i]);
}
totalHospitales = 0;
}

/* =========================================================
================== FUNCIONES DE APOYO ===================
========================================================= */

/* Copia un equipo médico campo por campo */
void copiarEquipo(struct EQUIPO_MEDICO *dest, struct EQUIPO_MEDICO *orig) {
strcpy(dest->Nombre, orig->Nombre);
strcpy(dest->Marca, orig->Marca);
strcpy(dest->Modelo, orig->Modelo);
}

/* Copia una especialidad campo por campo */
void copiarEspecialidad(struct ESPECIALIDAD *dest, struct ESPECIALIDAD *orig) {
strcpy(dest->Nombre, orig->Nombre);
dest->CantidadDoctores = orig->CantidadDoctores;
dest->CantidadPacientes = orig->CantidadPacientes;
copiarEquipo(&dest->EquipoMedico, &orig->EquipoMedico);
}

/* Copia un trabajador campo por campo */
void copiarTrabajador(struct TRABAJADOR *dest, struct TRABAJADOR *orig) {
dest->NumTrabajador = orig->NumTrabajador;
dest->Sindicalizado = orig->Sindicalizado;
}

/* Copia un doctor campo por campo */
void copiarDoctor(struct DOCTOR *dest, struct DOCTOR *orig) {
strcpy(dest->Nombre, orig->Nombre);
dest->Edad = orig->Edad;
copiarEspecialidad(&dest->Especialidad, &orig->Especialidad);
copiarTrabajador(&dest->Trabajador, &orig->Trabajador);
dest->CantidadPacientes = orig->CantidadPacientes;
}

/* Copia un hospital básico campo por campo */
void copiarHospitalBasicoDesdeHospital(struct HOSPITAL_BASICO *dest, struct HOSPITAL *orig) {
strcpy(dest->Nombre, orig->Nombre);
strcpy(dest->Direccion, orig->Direccion);
}

/* Recalcula contadores de doctores y pacientes por especialidad */
void recalcularContadoresEspecialidades(int idxHospital) {
int i, j;

/* Primero se ponen en 0 */
for (i = 0; i < hospitales[idxHospital].cEspecialidades; i++) {
hospitales[idxHospital].Especialidades[i].CantidadDoctores = 0;
hospitales[idxHospital].Especialidades[i].CantidadPacientes = 0;
}

/* Se cuentan doctores por especialidad */
for (i = 0; i < hospitales[idxHospital].cDoctores; i++) {
for (j = 0; j < hospitales[idxHospital].cEspecialidades; j++) {
if (strcmp(hospitales[idxHospital].Doctores[i].Especialidad.Nombre,
hospitales[idxHospital].Especialidades[j].Nombre) == 0 &&
strlen(hospitales[idxHospital].Especialidades[j].Nombre) > 0) {
hospitales[idxHospital].Especialidades[j].CantidadDoctores++;
}
}
}

/* Se cuentan pacientes por especialidad */
for (i = 0; i < hospitales[idxHospital].cPacientes; i++) {
for (j = 0; j < hospitales[idxHospital].cEspecialidades; j++) {
if (strcmp(hospitales[idxHospital].Pacientes[i].Especialidad.Nombre,
hospitales[idxHospital].Especialidades[j].Nombre) == 0 &&
strlen(hospitales[idxHospital].Especialidades[j].Nombre) > 0) {
hospitales[idxHospital].Especialidades[j].CantidadPacientes++;
}
}
}
}

/* Recalcula cantidad de pacientes por doctor */
void recalcularContadoresDoctores(int idxHospital) {
int i, j;

for (i = 0; i < hospitales[idxHospital].cDoctores; i++) {
hospitales[idxHospital].Doctores[i].CantidadPacientes = 0;
}

for (i = 0; i < hospitales[idxHospital].cPacientes; i++) {
for (j = 0; j < hospitales[idxHospital].cDoctores; j++) {
if (hospitales[idxHospital].Pacientes[i].Doctor.Trabajador.NumTrabajador ==
hospitales[idxHospital].Doctores[j].Trabajador.NumTrabajador &&
hospitales[idxHospital].Doctores[j].Trabajador.NumTrabajador != 0) {
hospitales[idxHospital].Doctores[j].CantidadPacientes++;
}
}
}
}

/* Recalcula todo lo dependiente */
void recalcularSistemaHospital(int idxHospital) {
recalcularContadoresEspecialidades(idxHospital);
recalcularContadoresDoctores(idxHospital);
}

/* =========================================================
================ FUNCIONES DE AGREGAR DATOS =============
========================================================= */

void agregarHospital() {
int op;
int idx;

if (totalHospitales >= MAX_HOSPITALES) {
printf("Ya no se pueden agregar mas hospitales.\n");
return;
}

idx = totalHospitales;

/* Se limpia completamente antes de capturar datos */
limpiarHospital(&hospitales[idx]);

do {
printf("\n--- AGREGAR HOSPITAL #%d ---\n", idx + 1);
printf("1. Nombre\n");
printf("2. Direccion\n");
printf("3. Guardar y regresar\n");
op = leerOpcion("Seleccion: ", 1, 3);

switch (op) {
case 1:
leerCadena("Nombre del hospital: ", hospitales[idx].Nombre, MAX_NOMBRE);
break;
case 2:
leerCadena("Direccion del hospital: ", hospitales[idx].Direccion, MAX_DIRECCION);
break;
case 3:
totalHospitales++;
printf("Hospital guardado correctamente.\n");
break;
}
} while (op != 3);
}

int seleccionarHospital() {
int h;

if (totalHospitales == 0) {
printf("No hay hospitales registrados.\n");
return -1;
}

printf("\nHospitales registrados: %d\n", totalHospitales);
h = leerOpcion("Seleccione hospital (1-2 segun disponibles): ", 1, totalHospitales);
return h - 1;
}

void agregarEspecialidad(int idxHospital) {
int op, idx, equipoElegido;

if (hospitales[idxHospital].cEspecialidades >= MAX_ESPECIALIDADES) {
printf("Ya no se pueden agregar mas especialidades en este hospital.\n");
return;
}

idx = hospitales[idxHospital].cEspecialidades;
limpiarEspecialidad(&hospitales[idxHospital].Especialidades[idx]);

do {
printf("\n--- AGREGAR ESPECIALIDAD #%d ---\n", idx + 1);
printf("1. Nombre\n");
printf("2. Asignar equipo medico existente del hospital\n");
printf("3. Guardar y regresar\n");
op = leerOpcion("Seleccion: ", 1, 3);

switch (op) {
case 1:
leerCadena("Nombre de la especialidad: ",
hospitales[idxHospital].Especialidades[idx].Nombre,
MAX_NOMBRE);
break;

case 2:
if (hospitales[idxHospital].cEquipos == 0) {
printf("No hay equipos medicos registrados en este hospital.\n");
} else {
printf("Equipos almacenados: %d\n", hospitales[idxHospital].cEquipos);
equipoElegido = leerOpcion("Seleccione equipo: ",
1,
hospitales[idxHospital].cEquipos);

/* Copia campo por campo, sin asignacion directa de estructuras */
copiarEquipo(
&hospitales[idxHospital].Especialidades[idx].EquipoMedico,
&hospitales[idxHospital].Equipos[equipoElegido - 1]
);

printf("Equipo asignado a la especialidad.\n");
}
break;

case 3:
/* Cantidades inician en 0 */
hospitales[idxHospital].Especialidades[idx].CantidadDoctores = 0;
hospitales[idxHospital].Especialidades[idx].CantidadPacientes = 0;
hospitales[idxHospital].cEspecialidades++;
printf("Especialidad guardada correctamente.\n");
break;
}
} while (op != 3);
}

