void agregarPaciente(int idxHospital) {
int op, idx, doc, esp;

if (hospitales[idxHospital].cPacientes >= MAX_PACIENTES) {
printf("Ya no se pueden agregar mas pacientes en este hospital.\n");
return;
}

idx = hospitales[idxHospital].cPacientes;
limpiarPaciente(&hospitales[idxHospital].Pacientes[idx]);

/* Desde el inicio se copia el hospital correspondiente */
copiarHospitalBasicoDesdeHospital(
&hospitales[idxHospital].Pacientes[idx].Hospital,
&hospitales[idxHospital]
);

do {
printf("\n--- AGREGAR PACIENTE #%d ---\n", idx + 1);
printf("1. Nombre\n");
printf("2. Edad\n");
printf("3. Numero de paciente (4 digitos)\n");
printf("4. Asignar doctor existente\n");
printf("5. Asignar especialidad existente\n");
printf("6. Mostrar hospital asignado automaticamente\n");
printf("7. Guardar y regresar\n");
op = leerOpcion("Seleccion: ", 1, 7);

switch (op) {
case 1:
leerCadena("Nombre del paciente: ",
hospitales[idxHospital].Pacientes[idx].Nombre,
MAX_NOMBRE);
break;

case 2:
hospitales[idxHospital].Pacientes[idx].Edad =
leerEntero("Edad del paciente: ");
if (hospitales[idxHospital].Pacientes[idx].Edad < 0) {
hospitales[idxHospital].Pacientes[idx].Edad = 0;
}
break;

case 3:
hospitales[idxHospital].Pacientes[idx].NumPaciente =
leerNumero4Digitos("Numero de paciente: ");
break;

case 4:
if (hospitales[idxHospital].cDoctores == 0) {
printf("No hay doctores registrados en este hospital.\n");
} else {
printf("Doctores almacenados: %d\n", hospitales[idxHospital].cDoctores);
doc = leerOpcion("Seleccione doctor: ",
1,
hospitales[idxHospital].cDoctores);

copiarDoctor(
&hospitales[idxHospital].Pacientes[idx].Doctor,
&hospitales[idxHospital].Doctores[doc - 1]
);

printf("Doctor asignado al paciente.\n");
}
break;

case 5:
if (hospitales[idxHospital].cEspecialidades == 0) {
printf("No hay especialidades registradas en este hospital.\n");
} else {
printf("Especialidades almacenadas: %d\n", hospitales[idxHospital].cEspecialidades);
esp = leerOpcion("Seleccione especialidad: ",
1,
hospitales[idxHospital].cEspecialidades);

copiarEspecialidad(
&hospitales[idxHospital].Pacientes[idx].Especialidad,
&hospitales[idxHospital].Especialidades[esp - 1]
);

printf("Especialidad asignada al paciente.\n");
}
break;

case 6:
printf("Hospital asignado: %s | Direccion: %s\n",
hospitales[idxHospital].Pacientes[idx].Hospital.Nombre,
hospitales[idxHospital].Pacientes[idx].Hospital.Direccion);
break;

case 7:
hospitales[idxHospital].cPacientes++;
recalcularSistemaHospital(idxHospital);
printf("Paciente guardado correctamente.\n");
break;
}
} while (op != 7);
}

void menuAgregarDatos() {
int op, h;

do {
printf("\n========== MENU AGREGAR DATOS ==========\n");
printf("1. Hospital\n");
printf("2. Especialidad\n");
printf("3. Trabajador Doctor\n");
printf("4. Trabajador Intendencia\n");
printf("5. Paciente\n");
printf("6. Equipo Medico\n");
printf("7. Regresar\n");

op = leerOpcion("Seleccion: ", 1, 7);

switch (op) {
case 1:
agregarHospital();
break;

case 2:
h = seleccionarHospital();
if (h != -1) agregarEspecialidad(h);
break;

case 3:
h = seleccionarHospital();
if (h != -1) agregarDoctor(h);
break;

case 4:
h = seleccionarHospital();
if (h != -1) agregarIntendencia(h);
break;

case 5:
h = seleccionarHospital();
if (h != -1) agregarPaciente(h);
break;

case 6:
h = seleccionarHospital();
if (h != -1) agregarEquipoMedico(h);
break;

case 7:
break;
}
} while (op != 7);
}

