#include <stdio.h>

#define N 4

int lab[N][N] = {
    {1, 0, 0, 0},
    {1, 1, 0, 1},
    {0, 1, 0, 0},
    {1, 1, 1, 1}
};

int solucion[N][N];

int esValido(int x, int y) {
    return (x >= 0 && x < N && y >= 0 && y < N && lab[x][y] == 1);
}

int resolver(int x, int y) {
    if (x == N-1 && y == N-1) {
        solucion[x][y] = 1;
        return 1;
    }

    if (esValido(x, y)) {
        solucion[x][y] = 1;

        if (resolver(x + 1, y)) return 1;
        if (resolver(x, y + 1)) return 1;

        solucion[x][y] = 0; // backtrack
    }

    return 0;
}

int main() {
    if (resolver(0, 0)) {
        for (int i = 0; i < N; i++) {
            for (int j = 0; j < N; j++)
                printf("%d ", solucion[i][j]);
            printf("\n");
        }
    } else {
        printf("No hay solución\n");
    }
    return 0;
}
