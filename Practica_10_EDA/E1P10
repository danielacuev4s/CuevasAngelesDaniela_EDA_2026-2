#include <stdio.h>
#include <stdbool.h>

#define N 8

int tablero[N];

bool esSeguro(int fila, int col) {
    for (int i = 0; i < fila; i++) {
        if (tablero[i] == col || 
            tablero[i] - i == col - fila || 
            tablero[i] + i == col + fila) {
            return false;
        }
    }
    return true;
}

void resolver(int fila) {
    if (fila == N) {
        for (int i = 0; i < N; i++)
            printf("%d ", tablero[i]);
        printf("\n");
        return;
    }

    for (int col = 0; col < N; col++) {
        if (esSeguro(fila, col)) {
            tablero[fila] = col;
            resolver(fila + 1);
        }
    }
}

int main() {
    resolver(0);
    return 0;
}
