#include <stdio.h>
#include <stdlib.h>
#include <time.h>

// Merges two subarrays of arr[]
void merge(int arr[], int l, int m, int r) {

    int i, j, k;
    int n1 = m - l + 1;
    int n2 = r - m;

    // Create temp arrays
    int L[n1], R[n2];

    // Copy data to temp arrays
    for (i = 0; i < n1; i++)
        L[i] = arr[l + i];

    for (j = 0; j < n2; j++)
        R[j] = arr[m + 1 + j];

    // Merge temp arrays back into arr[]
    i = 0;
    j = 0;
    k = l;

    while (i < n1 && j < n2) {

        if (L[i] <= R[j]) {
            arr[k] = L[i];
            i++;
        } else {
            arr[k] = R[j];
            j++;
        }

        k++;
    }

    // Copy remaining elements of L[]
    while (i < n1) {
        arr[k] = L[i];
        i++;
        k++;
    }

    // Copy remaining elements of R[]
    while (j < n2) {
        arr[k] = R[j];
        j++;
        k++;
    }
}

// MergeSort function
void mergeSort(int arr[], int l, int r) {

    if (l < r) {

        int m = l + (r - l) / 2;

        // Sort first and second halves
        mergeSort(arr, l, m);
        mergeSort(arr, m + 1, r);

        // Merge sorted halves
        merge(arr, l, m, r);
    }
}

// Driver code
int main() {

    int arr[100]; //Se modifica de acuerdo a las posiciones requeridas
    int arr_size = 100; //Se modifica de acuerdo a las posiciones requeridas

    // Inicializar semilla aleatoria
    srand(time(NULL));

    // Llenar arreglo con números aleatorios del 0 al 999
    for (int i = 0; i < arr_size; i++) {
        arr[i] = rand() % 1000;
    }

    // Mostrar arreglo original
    printf("Arreglo original:\n");
    for (int i = 0; i < arr_size; i++) {
        printf("%d ", arr[i]);
    }

    // Ordenar arreglo
    mergeSort(arr, 0, arr_size - 1);

    // Mostrar arreglo ordenado
    printf("\n\nArreglo ordenado:\n");
    for (int i = 0; i < arr_size; i++) {
        printf("%d ", arr[i]);
    }

    printf("\n");

    return 0;
}
